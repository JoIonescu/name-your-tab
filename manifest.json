{
  "manifest_version": 3,
  "name": "Tab Namer",
  "version": "2.0",
  "description": "Shows hostname on hover. Double-click any tab to rename it.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "css": ["content_style.css"],
      "run_at": "document_end"
    }
  ]
}
